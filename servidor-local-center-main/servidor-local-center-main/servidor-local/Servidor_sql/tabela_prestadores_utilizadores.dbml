Table table_users [headercolor: #175e7a] {
	id varchar(255) [ pk, not null, unique ]
	name varchar(50) [ not null ]
	number_identifier varchar(100) [ not null ]
	birth_date date [ not null ]
	email varchar(100) [ not null ]
	phone_number varchar(100)
	country varchar(100) [ not null ]
	city varchar(100) [ not null ]
	enabled boolean [ not null ]
	created_at datetime [ not null ]
	updated_at datetime [ not null ]
}

Table table_prestadores [headercolor: #175e7a] {
	id integer [ pk, increment, not null, unique ]
	urgency_fee decimal(10, 2)
	discount decimal(10, 2)
	minimum_for_discount decimal(10, 2)
	nif numeric [ not null ]
	profession varchar(100) [ not null ]
	enabled boolean [ not null ]
	created_at datetime [ not null ]
	updated_at datetime [ not null ]
}

